# Example Dockerfile for an application using StackSense
# Copy and customize this for your application

FROM python:3.11-slim

WORKDIR /app

# Install system dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc \
    libpq-dev \
    libpq5 \
    && rm -rf /var/lib/apt/lists/*

# Copy project files first (for better caching)
COPY pyproject.toml ./
COPY MANIFEST.in* ./
COPY stacksense/ ./stacksense/

# Install StackSense from source with PostgreSQL support
RUN pip install --no-cache-dir --upgrade pip setuptools wheel && \
    pip install --no-cache-dir -e ".[postgres]"

# Copy requirements if they exist (optional)
COPY requirements.example.txt* requirements.txt* ./

# Install additional dependencies if requirements.txt exists
RUN if [ -f requirements.txt ]; then \
        pip install --no-cache-dir -r requirements.txt; \
    fi

# Copy application code
# Option 1: Use example app (default)
COPY docs/deployment/example_app.py ./example_app.py
CMD ["python", "example_app.py"]

# Option 2: Copy your own app (uncomment and customize)
# COPY app.py ./
# COPY your_app/ ./your_app/
# CMD ["python", "app.py"]

# Set environment variables
ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    STACKSENSE_ENABLE_DB=true \
    STACKSENSE_DB_URL=postgresql://stacksense:stacksense@postgres:5432/stacksense

# Expose port
EXPOSE 8000

